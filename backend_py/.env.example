# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017
DATABASE_NAME=swasthya_db

# Server Configuration
HOST=0.0.0.0
PORT=3003
SECRET_KEY=your-super-secret-key-change-this-in-production

# Public URL (for QR codes and external access)
PUBLIC_URL=http://localhost:3003

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=Swasthya Healthcare

# Twilio SMS Configuration (Optional)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ngrok Configuration (Optional, for public tunneling)
NGROK_AUTHTOKEN=your-ngrok-auth-token

# QR Token Expiry (in days)
QR_TOKEN_EXPIRY_DAYS=7

# Logging Level
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
# ENVIRONMENT=production
